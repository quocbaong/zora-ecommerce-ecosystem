# ============================================================
# Template .env cho PRODUCTION (copy thành .env trên EC2, điền giá trị thật).
# KHÔNG commit .env thật. File *.example này chỉ là checklist tên biến.
# ============================================================

# ---- Deploy / hạ tầng prod (chỉ dùng ở prod) ----
CADDY_DOMAIN=13-228-45-67.sslip.io     # <elastic-ip dạng gạch nối>.sslip.io
ACME_EMAIL=you@example.com             # email Let's Encrypt (có thể để trống)
IMAGE_PREFIX=ghcr.io/buimanhhieu       # namespace GHCR (lowercase)
TAG=latest                             # đổi sang <git-sha> để rollback
JAVA_TOOL_OPTIONS=-Xms128m -Xmx512m    # cap heap cho mọi JVM (Node bỏ qua biến này)

# ---- App ----
NODE_ENV=production
PORT=8000                              # gateway nghe nội bộ cổng 8000

# ---- PostgreSQL (container) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=__CHANGE_ME_strong_password__
POSTGRES_DB=user_db

# ---- Redis (container) ----
REDIS_HOST=redis
REDIS_PORT=6379

# ---- JWT (tạo secret MỚI cho prod) ----
JWT_SECRET=__CHANGE_ME_base64_secret__

# ---- Inter-service URLs (service-name trong docker network) ----
GATEWAY_SERVICE_URL=gateway-service:8080
AUTH_SERVICE_URL=auth-service:8081
USER_SERVICE_URL=user-service:8082
PRODUCT_SERVICE_URL=product-service:8083
CART_SERVICE_URL=cart-service:8084
ORDER_SERVICE_URL=order-service:8085
PAYMENT_SERVICE_URL=payment-service:8086
NOTIFICATION_SERVICE_URL=notification-service:8087
CHAT_SERVICE_URL=chat-service:8088

# ---- AWS (S3 + DynamoDB, đã có sẵn) ----
AWS_ACCESS_KEY_ID=__CHANGE_ME__
AWS_SECRET_ACCESS_KEY=__CHANGE_ME__
AWS_REGION=ap-southeast-1
S3_BUCKET_CHAT=ecommerce-chat-service-zora

# ---- DynamoDB tables (chat-service) ----
DYNAMODB_TABLE_CONVERSATIONS=chat_conversations
DYNAMODB_TABLE_MESSAGES=chat_messages
DYNAMODB_TABLE_GROUPS=chat_groups
DYNAMODB_TABLE_GROUP_MEMBERS=chat_group_members
DYNAMODB_TABLE_GROUP_MESSAGES=chat_group_messages
DYNAMODB_TABLE_GROUP_PINS=chat_group_pins
DYNAMODB_TABLE_POLLS=chat_polls
DYNAMODB_TABLE_POLL_VOTES=chat_poll_votes
DYNAMODB_TABLE_REMINDERS=chat_reminders

# ---- Email (SMTP — OTP, verify) ----
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=__CHANGE_ME__
MAIL_PASSWORD=__CHANGE_ME_app_password__

# ---- AI (ai-service) ----
GEMINI_API_KEY=__CHANGE_ME__
GROQ_API_KEY=__CHANGE_ME__
GROQ_MODEL=llama-3.3-70b-versatile
AI_TOOL_CALL_ENABLED=true
AI_DAILY_LIMIT=100
FPT_AI_API_KEY=__CHANGE_ME__

# ---- Payment (tùy chọn — chỉ cần nếu test thanh toán online) ----
STRIPE_SECRET_KEY=__CHANGE_ME__
STRIPE_WEBHOOK_SECRET=__CHANGE_ME__
PAYOS_CLIENT_ID=__CHANGE_ME__
PAYOS_API_KEY=__CHANGE_ME__
PAYOS_CHECKSUM_KEY=__CHANGE_ME__

# ---- GHN shipping ----
GHN_BASE_URL=https://dev-online-gateway.ghn.vn
GHN_TOKEN=__CHANGE_ME__
GHN_SHOP_ID=__CHANGE_ME__
